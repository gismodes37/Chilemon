 * ChileMon - Ejemplo de configuración local.
 *
 * Copie este archivo como config/local.php o permita que el instalador lo genere.
 * Este archivo NO debe subirse al repositorio como local.php real.
 */

return [
    /**
     * Nodo local ASL del servidor donde se instala ChileMon.
     * Debe coincidir con el nodo configurado en este equipo.
     */
    return [
    'local_node' => '12345',
    ];

    /**
     * Texto opcional mostrado debajo del nombre de la aplicación.
     */
    'header_tagline' => 'Nodo local ChileMon',

    /**
     * IP o nombre DNS del servidor donde quedará publicado el dashboard.
     * Se usa como referencia para construir la URL de acceso.
     */
    'server_host' => 'localhost',

    /**
     * Ruta raíz del proyecto.
     */
    'project_root' => '/opt/chilemon',

    /**
     * Base de datos SQLite principal.
     */
    'database_path' => '/opt/chilemon/data/chilemon.sqlite',

    /**
     * Wrapper seguro para comandos rpt.
     */
    'wrapper_path' => '/usr/local/bin/chilemon-rpt',

    /**
     * Parámetros de conexión al Asterisk Manager Interface (AMI).
     */
    'ami_host' => '127.0.0.1',
    'ami_port' => 5038,
    'ami_user' => 'admin',
    'ami_pass' => 'REEMPLAZAR_CON_TU_CLAVE_AMI_REAL',
    'ami_timeout' => 3,

    /**
     * Whitelist de nodos permitidos para connect/disconnect.
     * Vacío = todos los nodos permitidos.
     * Ejemplo: ['494780', '123456']
     */
    'node_whitelist' => [],

    /**
     * Whitelist de IPs exentas de rate limiting.
     * Vacío = rate limiting para todos.
     * Ejemplo: ['127.0.0.1', '192.168.1.100']
     */
    'rate_limit_whitelist' => [],

    /**
     * WebRTC Audio Bridge — Configuración del daemon Python.
     *
     * El bridge corre en un puerto HTTP/WS separado (default 9091)
     * y se conecta a Asterisk vía IAX2 como un phone extension.
     *
     * webrtc_port:    Puerto donde escucha el bridge (GET /health, WS /ws)
     * webrtc_secret:  Clave HMAC para autenticar tokens WebSocket
     * iax_phone_user: Usuario IAX2 para registrarse en Asterisk
     * iax_phone_pass: Clave IAX2 del phone extension
     */
    'webrtc_port' => 9091,
    'webrtc_secret' => 'REEMPLAZAR_CON_WEBRTC_SECRET_REAL',
    'iax_phone_user' => 'webrtc-bridge',
    'iax_phone_pass' => 'REEMPLAZAR_CON_IAX_PHONE_PASS_REAL',
];