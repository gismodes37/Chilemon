    'header_tagline' => 'Nodo local ChileMon',

    /**
     * IP o nombre DNS del servidor donde quedará publicado el dashboard.
     * Se usa como referencia para construir la URL de acceso.
     */
    'server_host' => 'localhost',

    /**
     * Ruta raíz del proyecto.
     */
    'project_root' => '/opt/chilemon',

    /**
     * Base de datos SQLite principal.
     */
    'database_path' => '/opt/chilemon/data/chilemon.sqlite',

    /**
     * Wrapper seguro para comandos rpt.
     */
    'wrapper_path' => '/usr/local/bin/chilemon-rpt',

    /**
     * Parámetros de conexión al Asterisk Manager Interface (AMI).
