#!/usr/bin/env bash
# ==============================================================================
# ChileMon - Wrapper seguro para comandos rpt de Asterisk (v0.3.1)
# ==============================================================================
# Este script actúa como un puente seguro entre PHP y Asterisk.
# Limpia los parámetros de entrada y los ejecuta mediante 'rpt fun'.
#
# Soporte EchoLink:
#   Los nodos EchoLink en AllStarLink usan prefijo 3 + 6 dígitos (7 total).
#   Ej: EchoLink 1234 → 3001234 en ASL.
#   Se conectan/desconectan con los mismos comandos *3 y *1 que nodos ASL.
# ==============================================================================

# Limpieza de parámetros para evitar inyecciones y fallos de comillas desde PHP
CMD=$(echo ${1:-} | tr -d "'\"")
LOCAL=$(echo ${2:-} | tr -d "'\"")
REMOTE=$(echo ${3:-} | tr -d "'\"")

# LOG DE DEPURACIÓN (descomentar para ver qué llega desde la web)
# echo "[$(date)] WEB_CMD: $CMD LOCAL:$LOCAL REMOTE:$REMOTE" >> /tmp/chilemon.log

case "$CMD" in
    nodes)
        # Lista los nodos conectados actualmente
        /usr/sbin/asterisk -rx "rpt nodes $LOCAL"
        ;;
    stats)
        # Obtiene estadísticas detalladas del nodo local
        /usr/sbin/asterisk -rx "rpt stats $LOCAL"
        ;;
    connect)
        # Conectar a un nodo remoto (*3 = transceive)
        # Funciona tanto para nodos ASL normales como EchoLink (prefijo 3xxxxxx)
        /usr/sbin/asterisk -rx "rpt fun $LOCAL *3$REMOTE"
        ;;
    disconnect)
        # Desconecta un nodo remoto específico (*1 = disconnect specific)
        /usr/sbin/asterisk -rx "rpt fun $LOCAL *1$REMOTE"
        ;;
    sys-restart-asterisk)
        # Reinicia el servicio Asterisk completo
        systemctl restart asterisk
        ;;
    sys-restart-apache)
        # Reinicia el servidor web Apache
        systemctl restart apache2
        ;;
    sys-poweroff)
        # Apaga el hardware físicamente
        poweroff
        ;;
    *)
        echo "Comando invalido: $CMD" >> /tmp/chilemon.log
        exit 1
        ;;
esac