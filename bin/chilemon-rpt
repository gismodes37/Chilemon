#!/bin/bash
# ---------------------------------------------------------
# ChileMon - Wrapper seguro corregido (v0.2.2)
# ---------------------------------------------------------
# Este script actúa como un puente seguro entre PHP y Asterisk.
# Limpia los parámetros de entrada y los ejecuta mediante 'rpt fun'.
# ---------------------------------------------------------

# Limpiar parámetros de comillas para evitar fallos de ejecución desde la web
CMD=$(echo $1 | tr -d "'\"")
LOCAL=$(echo $2 | tr -d "'\"")
REMOTE=$(echo $3 | tr -d "'\"")

# Registro opcional para depuración en el nodo (descomentar si es necesario)
# echo "[$(date)] EJECUTANDO: $CMD LOCAL:$LOCAL REMOTE:$REMOTE" >> /tmp/chilemon.log

case "$CMD" in
    nodes)
        # Lista los nodos conectados actualmente
        /usr/sbin/asterisk -rx "rpt nodes $LOCAL"
        ;;
    stats)
        # Obtiene estadísticas detalladas del nodo local
        /usr/sbin/asterisk -rx "rpt stats $LOCAL"
        ;;
    connect)
        # Realiza una conexión hacia un nodo remoto (*3 = transceive)
        /usr/sbin/asterisk -rx "rpt fun $LOCAL *3$REMOTE"
        ;;
    disconnect)
        # Desconecta un nodo remoto específico (*1 = disconnect specific)
        /usr/sbin/asterisk -rx "rpt fun $LOCAL *1$REMOTE"
        ;;
    sys-restart-asterisk)
        # Reinicia el servicio Asterisk completo
        /usr/bin/systemctl restart asterisk
        ;;
    sys-restart-apache)
        # Reinicia el servidor web Apache
        /usr/bin/systemctl restart apache2
        ;;
    sys-poweroff)
        # Apaga el hardware físicamente
        /usr/sbin/poweroff
        ;;
    *)
        echo "Comando invalido: $CMD"
        exit 1
        ;;
esac